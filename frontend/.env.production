# Production environment — used by `npm run build`
# REACT_APP_API_URL is left EMPTY so all /api calls are relative to the same origin.
# On AWS Amplify + API Gateway / ALB, both frontend and backend live under the same domain:
#   https://chalokisaan.in        → React SPA  (served by Amplify / CloudFront)
#   https://chalokisaan.in/api    → FastAPI     (behind ALB → ECS / Elastic Beanstalk)
REACT_APP_API_URL=
REACT_APP_DEV_BYPASS_AUTH=false
