# AWS Configuration
AWS_ACCESS_KEY_ID=your_access_key_here
AWS_SECRET_ACCESS_KEY=your_secret_key_here
AWS_REGION=ap-south-1

# AWS Services
AWS_TRANSCRIBE_REGION=ap-south-1
AWS_BEDROCK_REGION=ap-south-1
AWS_SAGEMAKER_REGION=ap-south-1
AWS_S3_BUCKET=chalo-kisaan-bucket

# Database Configuration
DATABASE_URL=postgresql://user:password@localhost:5432/chalo_kisaan
DATABASE_ECHO=false

# API Configuration
API_HOST=0.0.0.0
API_PORT=8000
API_DEBUG=false

# Frontend Configuration
VITE_API_URL=http://localhost:8000
VITE_APP_NAME=Chalo Kisaan
VITE_APP_VERSION=0.1.0

# Authentication
JWT_SECRET_KEY=your_jwt_secret_key_here
JWT_ALGORITHM=HS256
JWT_EXPIRATION_HOURS=1

# Logging
LOG_LEVEL=INFO
LOG_FILE=logs/app.log

# Feature Flags
ENABLE_VOICE_TRANSCRIPTION=true
ENABLE_BUSINESS_PLAN_GENERATION=true
ENABLE_VISUALIZATION_GENERATION=true
ENABLE_OFFLINE_MODE=true
ENABLE_CROSS_DEVICE_SYNC=true

# Email Configuration (Optional)
SMTP_SERVER=smtp.gmail.com
SMTP_PORT=587
SMTP_USERNAME=your_email@gmail.com
SMTP_PASSWORD=your_app_password

# Sentry Configuration (Optional)
SENTRY_DSN=

# Analytics (Optional)
ANALYTICS_ENABLED=false
ANALYTICS_KEY=
